name: Android Build

on:
  push:
    branches: [ "master", "main", "develop" ]
    tags: [ "*" ] # 只要打标签就触发 Release
  pull_request:
    branches: [ "master", "main", "develop" ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'

      - name: Setup Gradle
        uses: gradle/actions/setup-gradle@v4

      - name: Grant execute permission for gradlew
        run: chmod +x gradlew

      # 编译 Debug 版
      - name: Build Debug APK
        run: ./gradlew assembleDebug

      # 编译 Release 版
      - name: Build Release APK
        run: ./gradlew assembleRelease

      # 签名并统一命名
      - name: Sign and Rename APK
        env:
          SIGNING_KEY: ${{ secrets.SIGNING_KEY }}
        run: |
          # 1. 处理 Debug 包：直接重命名
          DEBUG_PATH=$(find app/build/outputs/apk/debug -name "*.apk" | head -1)
          mv "$DEBUG_PATH" app/build/outputs/apk/debug/debug.apk

          # 2. 处理 Release 包：如果有 Key 就签名并改名
          if [ -n "$SIGNING_KEY" ]; then
            echo "$SIGNING_KEY" | base64 -d > /tmp/release.jks
            BUILD_TOOLS=$(ls -d $ANDROID_HOME/build-tools/*/ | sort -V | tail -1)
            UNSIGNED_APK=$(find app/build/outputs/apk/release -name "*-unsigned.apk" | head -1)
            
            # Zipalign 并重命名为 release.apk
            ${BUILD_TOOLS}zipalign -f 4 "$UNSIGNED_APK" app/build/outputs/apk/release/release.apk
            
            # 签名
            ${BUILD_TOOLS}apksigner sign \
              --ks /tmp/release.jks \
              --ks-key-alias "${{ secrets.ALIAS }}" \
              --ks-pass "pass:${{ secrets.KEYSTORE_PASSWORD }}" \
              --key-pass "pass:${{ secrets.KEY_PASSWORD }}" \
              app/build/outputs/apk/release/release.apk
            
            rm /tmp/release.jks
          else
            # 如果没配置签名，就把未命名的包改名为 release-unsigned.apk 方便区分
            RELEASE_PATH=$(find app/build/outputs/apk/release -name "*.apk" | head -1)
            mv "$RELEASE_PATH" app/build/outputs/apk/release/release-unsigned.apk
          fi

      # 上传 Artifacts (Action 里的产物)
      - name: Upload Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: apks
          path: |
            app/build/outputs/apk/debug/debug.apk
            app/build/outputs/apk/release/release.apk

      # 发布到 Release 页面
      - name: Create GitHub Release
        if: startsWith(github.ref, 'refs/tags/')
        uses: softprops/action-gh-release@v2
        with:
          files: |
            app/build/outputs/apk/debug/debug.apk
            app/build/outputs/apk/release/release.apk
          generate_release_notes: true
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
